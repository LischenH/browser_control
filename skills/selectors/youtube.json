    "ytd-playlist-add-to-option-renderer[playlist-id='WL']",
    "yt-playlist-add-to-option-renderer[playlist-id='WL']",
    "ytd-playlist-add-to-option-renderer:first-child"
  ],
  "_comment_watch_later_removed": "Removed :first-child positional fallbacks — if the canonical [playlist-id='WL'] fails, positional fallbacks click the first playlist item regardless of content (not Watch Later). Fail gracefully instead of clicking the wrong playlist.",
  "playlist_menu": [
    "ytd-playlist-add-to-option-renderer",
    "yt-playlist-add-to-option-renderer",
